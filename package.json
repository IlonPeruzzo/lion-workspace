{
  "name": "lion-workspace",
  "version": "1.3.66",
  "description": "Lion Workspace - Gestao para Editores de Video",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "release:win": "electron-builder --win --publish always",
    "release:mac": "electron-builder --mac --publish always",
    "release": "electron-builder --win --mac --publish always",
    "version:patch": "npm version patch && git push && git push --tags",
    "version:minor": "npm version minor && git push && git push --tags",
    "version:major": "npm version major && git push && git push --tags"
  },
  "build": {
    "appId": "com.lionworkspace.app",
    "productName": "Lion Workspace",
    "publish": [
      {
        "provider": "github",
        "owner": "IlonPeruzzo",
        "repo": "lion-workspace"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": false,
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "Lion Workspace",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "artifactName": "Lion-Workspace-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "identity": null,
      "category": "public.app-category.productivity",
      "darkModeSupport": true,
      "icon": "build/icon.png",
      "artifactName": "Lion-Workspace-${version}-${arch}.${ext}"
    },
    "dmg": {
      "background": null,
      "icon": "build/icon.png",
      "iconSize": 100,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "build/icon.png",
      "node_modules/**/*",
      "!node_modules/**/*.{md,markdown,ts,tsx,map,d.ts,gypi}",
      "!node_modules/**/{test,tests,__tests__,examples,example,docs,doc}/**",
      "!node_modules/**/.bin/**",
      "!node_modules/**/.github/**"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/@imgly/background-removal-node/**/*",
      "node_modules/@imgly/background-removal/**/*",
      "node_modules/onnxruntime-node/**/*",
      "node_modules/onnxruntime-common/**/*",
      "node_modules/sharp/**/*"
    ],
    "extraResources": [
      {
        "from": "premiere-plugin",
        "to": "premiere-plugin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "after-plugin",
        "to": "after-plugin",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@imgly/background-removal": "^1.7.0",
    "@imgly/background-removal-node": "^1.4.5",
    "@supabase/supabase-js": "^2.103.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  }
}
