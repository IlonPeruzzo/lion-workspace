{
  "name": "lion-workspace",
  "version": "1.0.0",
  "description": "Lion Workspace - Gestao para Editores de Video",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable",
    "build:mac": "electron-builder --mac --x64 --arm64",
    "build:all": "electron-builder --win portable --mac"
  },
  "build": {
    "appId": "com.lionworkspace.app",
    "productName": "Lion Workspace",
    "win": {
      "target": "portable",
      "sign": false
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "identity": null,
      "category": "public.app-category.productivity",
      "darkModeSupport": true
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html"
    ],
    "extraResources": [
      {
        "from": "premiere-plugin",
        "to": "premiere-plugin",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
